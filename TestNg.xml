<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Playwright Test Suite" parallel="classes" thread-count="5">
    <listeners>
        <listener class-name="listeners.AllureScreenshotListener"/>
        <listener class-name="listeners.RetryTransformer"/>
    </listeners>
    <test name="All Tests">
        <packages>
            <package name="tests.ui"/>
        </packages>
    </test>
</suite>
